  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 6
  indentLevel: 0
  storyText: "In this painting, notice the elegant male and female singers\u2014known
    as 'li\u1EC1n anh' and 'li\u1EC1n ch\u1ECB'\u2014wearing traditional costumes
    and singing gracefully together."
