  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 7
  indentLevel: 0
  storyText: This artwork beautifully captures the romantic and joyful spirit of
    spring festivals, where villagers gathered to celebrate community and love through
    music.
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 0}
