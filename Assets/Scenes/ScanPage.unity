  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 1
  indentLevel: 0
  storyText: "Hello! This is Dong Ho. \nDong Ho is Vietnamese folk painting.\nIt
    is connected with people daily life in the past. "
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 8300000, guid: a928ba43d8802554b93420b4fce059e5, type: 3}
