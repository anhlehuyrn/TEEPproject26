  waitForVO: 0
  setSayDialog: {fileID: 0}
--- !u!114 &1355906788
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
