--- !u!114 &1355906787
MonoBehaviour:
  m_ObjectHideFlags: 2
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1355906780}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 2
  indentLevel: 0
  storyText: This famous piece is 'The Mice's Wedding'. Notice how the mice must
    offer a bird and a fish to bribe the big cat so their wedding can proceed safely!
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 8300000, guid: 834412c7aee8ff647974b2912072a91f, type: 3}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
  fadeWhenDone: 1
  waitForClick: 1
