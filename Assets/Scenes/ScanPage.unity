  m_Name: 
  m_EditorClassIdentifier: Fungus::Fungus.Say
  itemId: 5
  indentLevel: 0
  storyText: Let's move on to the next one. This is Quan Ho. It is a traditional
    Vietnamese folk song, deeply connected with people's entertainment and social
    life in the past.
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 8300000, guid: c52cf918cd53e6f4cb85ece0081e1557, type: 3}
